# Copy this file to .env and fill in your Gmail SMTP credentials.
# Use a Gmail App Password, not your normal Gmail password.

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_USER=yourname@gmail.com
EMAIL_PASS=your-16-char-app-password

# Existing project variable names also work:
# SMS_SHIELD_SMTP_SERVER=smtp.gmail.com
# SMS_SHIELD_SMTP_PORT=587
# SMS_SHIELD_SMTP_EMAIL=yourname@gmail.com
# SMS_SHIELD_SMTP_PASSWORD=your-16-char-app-password
